# ─────────────────────────────────────────────────────────────
# Server roles (DigitalOcean Droplets)
#   app-server  → 157.245.138.153  (NYC1) ← this app runs here
#   main-server → 168.144.35.138   (SGP1) ← Graylog lives here
# ─────────────────────────────────────────────────────────────

# Node environment
NODE_ENV=production

# Server config
PORT=3000
APP_NAME=graylog-express-app
SERVER_NAME=app-server          # label shown in every Graylog message

# Graylog GELF UDP config
# Point to main-server where Graylog is installed
GRAYLOG_HOST=168.144.35.138
GRAYLOG_PORT=12201

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*
