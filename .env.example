# Node environment
NODE_ENV=production

# Server config
PORT=3000
APP_NAME=graylog-express-app
SERVER_NAME=my-ubuntu-server

# Graylog GELF UDP config
GRAYLOG_HOST=YOUR_GRAYLOG_SERVER_IP
GRAYLOG_PORT=12201

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS (comma-separated origins, or * for all)
CORS_ORIGIN=*
